Host gss-csp*
	IdentityFile ~/.ssh/id_rsa

Host vcenter-*, nsxmgr-*
	PubkeyAuthentication=no

Host gitlab.eng.vmware.com
	IdentityFile ~/.ssh/id_rsa

Host github.gwd.broadcom.net
	IdentityFile ~/.ssh/avgo-broadcom
	User aa000650

Host vcf-csp.acc.broadcom.net
    User aa000650
    PubkeyAuthentication=No
    PasswordAuthentication=yes
    PreferredAuthentications=keyboard-interactive,password

# Added by Krypton
#Host *
#     IdentityAgent ~/.kr/krd-agent.sock
#     ProxyCommand /usr/local/bin/krssh %h %p
#     IdentityFile ~/.ssh/id_krypton
#     IdentityFile ~/.ssh/id_rsa

Host pci-bastion
  HostName 52.5.5.158
  ProxyCommand none
  ForwardAgent yes

Host prod-bastion
  HostName 54.67.58.131
  ProxyCommand none
  ForwardAgent yes

Host gitlab.com
	IdentityFile ~/.ssh/gitlab-personal

Host github.com
	IdentityFile ~/.ssh/github-personal

Host 54.171.197.240
    HostName 54.171.197.240
    User ubuntu
    IdentityFile ~/.ssh/aws_dev_key

Host *.tp-p-us-w-2 teleport-nlb.vmware-prod.net vco* vcg*
    UserKnownHostsFile "/Users/aherna/.tsh/known_hosts"
    IdentityFile "/Users/aherna/.tsh/keys/teleport.vmware-prod.net/aherna@vmware.com"
    CertificateFile "/Users/aherna/.tsh/keys/teleport.vmware-prod.net/aherna@vmware.com-ssh/tp-p-us-w-2-cert.pub"
    PubkeyAcceptedKeyTypes +ssh-rsa-cert-v01@openssh.com

# Flags for all tp-p-us-w-2 hosts except the proxy
Host *.tp-p-us-w-2 !teleport-nlb.vmware-prod.net
    Port 3022
    ProxyCommand "/usr/local/bin/tsh" proxy ssh --cluster=tp-p-us-w-2 --proxy=teleport-nlb.vmware-prod.net %r@%h:%p
